@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Items is { Count: > 0 })
{
    <!-- ── Thumbnail grid ── -->
    <div class="blb-gallery">
        @foreach (var item in VisibleItems)
        {
            var galleryItem = item;
            <button class="blb-thumb"
                    @onclick="@(() => OpenAsync(galleryItem))"
                    aria-label="@($"Open image: {galleryItem.Label}")">
                <img src="@CdnUrl(galleryItem.Src)"
                     alt="@galleryItem.Label"
                     loading="lazy" />
                <span class="blb-thumb-hint" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8" x2="11" y2="14"/>
                        <line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                </span>
            </button>
        }
    </div>

    <!-- ── Expand / collapse toggle (only when there are hidden items) ── -->
    @if (Items.Count > InitialVisible)
    {
        <button class="blb-gallery-toggle" @onclick="@(() => _isExpanded = !_isExpanded)"
                aria-expanded="@_isExpanded.ToString().ToLower()">
            @if (_isExpanded)
            {
                <span>Show less</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="18 15 12 9 6 15"/>
                </svg>
            }
            else
            {
                <span>Show @(Items.Count - InitialVisible) more</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            }
        </button>
    }

    <!-- ── Lightbox overlay (only when open) ── -->
    @if (_isOpen)
    {
        <div class="blb-overlay"
             role="dialog"
             aria-modal="true"
             aria-label="Image preview"
             tabindex="-1"
             @ref="_overlayRef"
             @onkeydown="HandleKeyDownAsync">
            <div class="blb-backdrop" @onclick="CloseAsync"></div>
            <div class="blb-panel">
                <button class="blb-close"
                        aria-label="Close image preview"
                        @onclick="CloseAsync">&#x2715;</button>
                <img class="blb-img" src="@_activeSrc" alt="@_activeAlt" />
                <a class="blb-link"
                   href="@_activeSrc"
                   target="_blank"
                   rel="noopener noreferrer">
                    &#x2197;&nbsp;View full image
                </a>
            </div>
        </div>
    }
}

@code {
    /// <summary>Gallery items to display.</summary>
    [Parameter, EditorRequired] public List<GalleryItem> Items { get; set; } = default!;

    /// <summary>The content slug, used as the first argument to <see cref="CdnUrlResolver"/>.</summary>
    [Parameter, EditorRequired] public string Slug { get; set; } = default!;

    /// <summary>
    /// CDN URL resolver for this content type. Pass the service method directly,
    /// e.g. <c>CdnUrlResolver="BuildsService.ResolveCdnUrl"</c>.
    /// Signature: (slug, relativePath) => absoluteUrl
    /// </summary>
    [Parameter, EditorRequired] public Func<string, string, string> CdnUrlResolver { get; set; } = default!;

    // ── Collapse state ─────────────────────────────────────────────────────────

    private const int InitialVisible = 3;
    private bool _isExpanded = false;

    private IEnumerable<GalleryItem> VisibleItems =>
        _isExpanded ? Items : Items.Take(InitialVisible);

    // ── Lightbox state ─────────────────────────────────────────────────────────

    private bool             _isOpen    = false;
    private string           _activeSrc = string.Empty;
    private string           _activeAlt = string.Empty;
    private ElementReference _overlayRef;

    private string CdnUrl(string relativePath)
    {
        if (!relativePath.Contains('/'))
            relativePath = $"images/{relativePath}";
        return CdnUrlResolver(Slug, relativePath);
    }

    private async Task OpenAsync(GalleryItem item)
    {
        _activeSrc = CdnUrl(item.Src);
        _activeAlt = item.Label;
        _isOpen    = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("blbOpen", _overlayRef);
    }

    private async Task CloseAsync()
    {
        _isOpen = false;
        await JS.InvokeVoidAsync("blbClose");
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isOpen)
            await JS.InvokeVoidAsync("blbClose");
    }
}
