@implements IAsyncDisposable
@inject IJSRuntime JS
@inject CadBuildsService BuildsService

@if (Items is { Count: > 0 })
{
    <!-- ── Thumbnail grid ── -->
    <div class="blb-gallery">
        @foreach (var item in VisibleItems)
        {
            var i = item;
            <button class="blb-thumb"
                    @onclick="@(() => OpenAsync(i))"
                    aria-label="@($"Open image: {i.Label}")">
                <img src="@CdnUrl(i.Src)"
                     alt="@i.Label"
                     loading="lazy" />
                <span class="blb-thumb-hint" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8" x2="11" y2="14"/>
                        <line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                </span>
            </button>
        }
    </div>

    <!-- ── Expand / collapse toggle (only when there are hidden items) ── -->
    @if (Items.Count > InitialVisible)
    {
        <button class="blb-gallery-toggle" @onclick="@(() => _expanded = !_expanded)"
                aria-expanded="@_expanded.ToString().ToLower()">
            @if (_expanded)
            {
                <span>Show less</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="18 15 12 9 6 15"/>
                </svg>
            }
            else
            {
                <span>Show @(Items.Count - InitialVisible) more</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            }
        </button>
    }

    <!-- ── Lightbox overlay (only when open) ── -->
    @if (_isOpen)
    {
        <div class="blb-overlay"
             role="dialog"
             aria-modal="true"
             aria-label="Image preview"
             tabindex="-1"
             @ref="_overlayRef"
             @onkeydown="HandleKeyDownAsync">
            <div class="blb-backdrop" @onclick="CloseAsync"></div>
            <div class="blb-panel">
                <button class="blb-close"
                        aria-label="Close image preview"
                        @onclick="CloseAsync">&#x2715;</button>
                <img class="blb-img" src="@_activeSrc" alt="@_activeAlt" />
                <a class="blb-link"
                   href="@_activeSrc"
                   target="_blank"
                   rel="noopener noreferrer">
                    &#x2197;&nbsp;View full image
                </a>
            </div>
        </div>
    }
}

@code {
    /// <summary>Gallery items sourced from the build manifest.</summary>
    [Parameter, EditorRequired] public List<GalleryItem> Items { get; set; } = default!;

    /// <summary>The build slug, used to resolve CDN URLs for each image.</summary>
    [Parameter, EditorRequired] public string Slug { get; set; } = default!;

    // ── Collapse state ────────────────────────────────────────────────────────

    /// <summary>
    /// Number of items shown in the collapsed state (one full grid row at 3 columns).
    /// </summary>
    private const int InitialVisible = 3;

    private bool _expanded = false;

    /// <summary>The subset of items currently rendered in the grid.</summary>
    private IEnumerable<GalleryItem> VisibleItems =>
        _expanded ? Items : Items.Take(InitialVisible);

    // ── Lightbox state ────────────────────────────────────────────────────────

    private bool             _isOpen    = false;
    private string           _activeSrc = string.Empty;
    private string           _activeAlt = string.Empty;
    private ElementReference _overlayRef;

    private string CdnUrl(string relativePath)
    {
        // Gallery src values may be bare filenames (e.g. "02-model-cap.jpeg") when the
        // manifest hasn't fully resolved paths. All gallery images live under the build's
        // images/ subfolder, so prepend it when no directory separator is present.
        if (!relativePath.Contains('/'))
            relativePath = $"images/{relativePath}";
        return BuildsService.ResolveCdnUrl(Slug, relativePath);
    }

    private async Task OpenAsync(GalleryItem item)
    {
        _activeSrc = CdnUrl(item.Src);
        _activeAlt = item.Label;
        _isOpen    = true;
        StateHasChanged();
        // Focus the overlay so Escape key handling works immediately;
        // also locks body scroll while the lightbox is visible.
        await JS.InvokeVoidAsync("blbOpen", _overlayRef);
    }

    private async Task CloseAsync()
    {
        _isOpen = false;
        // Restore body scroll.
        await JS.InvokeVoidAsync("blbClose");
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseAsync();
    }

    public async ValueTask DisposeAsync()
    {
        // Restore scroll if the component is torn down while the lightbox is open
        // (e.g. user navigates away via the back button).
        if (_isOpen)
            await JS.InvokeVoidAsync("blbClose");
    }
}
