@if (IsLoading)
{
    <div class="projects-loading">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (HasError)
{
    <div class="projects-error">
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
            Hey, sorry — we couldn't load this page right now. Please try again in a moment.
        </MudAlert>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="OnRetry">
            Retry
        </MudButton>
    </div>
}
else
{
    <div class="project-detail-header">
        <h1 class="project-detail-title">@(Title ?? MarkdownProcessor.TitleCaseFromSlug(SubpageSlug ?? string.Empty))</h1>
        @if (ParentProject is not null)
        {
            <div class="project-subpage-parent-label">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                <span>@ParentProject.Title</span>
            </div>
        }
    </div>

    @if (Html is not null)
    {
        <div class="project-content-scope">
            <div class="project-content">
                @((MarkupString)Html)
            </div>
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public bool IsLoading { get; set; }
    [Parameter, EditorRequired] public bool HasError { get; set; }
    [Parameter] public string? SubpageSlug { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Html { get; set; }
    [Parameter] public ProjectEntry? ParentProject { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }
}
