@page "/programming"
@page "/programming/{Slug}"
@page "/programming/{Slug}/{Subpage}"

@using Blazor_Personal_Site.Models
@using Blazor_Personal_Site.Services
@inject ProgrammingService ProgrammingService
@inject NavigationManager Nav

<PageTitle>@ComputedPageTitle</PageTitle>

@if (Slug is null)
{
    <!-- ═══════════ LIST VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">

        <MudText Typo="Typo.h3" Class="mb-2">Programming Projects</MudText>
        <MudText Typo="Typo.body1" Style="opacity: 0.75;" Class="mb-8">
            Utilities, toy games, and mods — software built out of curiosity and necessity.
        </MudText>

        @if (_loadingManifest)
        {
            <div class="projects-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_manifestError)
        {
            <div class="projects-error">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    Hey, sorry — we couldn't fetch the projects right now. Please check back in a moment.
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="RetryManifestAsync">
                    Retry
                </MudButton>
            </div>
        }
        else if (_manifest is null || _manifest.Projects.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No projects found. Check back soon!
            </MudAlert>
        }
        else
        {
            <!-- ── Tag filter ── -->
            @if (AllTags.Count > 0)
            {
                <div class="projects-tag-filter">

                    <div class="projects-tag-search-wrapper">
                        <input class="projects-tag-search"
                               type="text"
                               placeholder="Filter by tag…"
                               value="@_tagQuery"
                               @oninput="@(e => _tagQuery = e.Value?.ToString() ?? string.Empty)"
                               @onfocus="@(() => _showTagSuggestions = true)"
                               @onblur="@(() => { if (!_mouseOverSuggestions) _showTagSuggestions = false; })"
                               autocomplete="off"
                               aria-label="Filter projects by tag" />
                        @if (_showTagSuggestions && TagSuggestions.Count > 0)
                        {
                            <ul class="projects-tag-suggestions" role="listbox"
                                @onmouseenter="@(() => _mouseOverSuggestions = true)"
                                @onmouseleave="@(() => _mouseOverSuggestions = false)">
                                @foreach (var suggestion in TagSuggestions)
                                {
                                    var s = suggestion;
                                    <li class="projects-tag-suggestion"
                                        role="option"
                                        @onmousedown:preventDefault="true"
                                        @onclick="@(() => AddTag(s))">@s</li>
                                }
                            </ul>
                        }
                    </div>

                    @if (_selectedTags.Count > 0)
                    {
                        <p class="projects-filter-count">@FilteredProjects.Count of @_manifest.Projects.Count projects</p>
                    }

                    @if (_selectedTags.Count > 0)
                    {
                        <div class="projects-active-tags">
                            @foreach (var tag in _selectedTags.ToList())
                            {
                                var t = tag;
                                <span class="projects-active-tag">
                                    @t
                                    <button class="projects-active-tag-remove"
                                            @onclick="@(() => RemoveTag(t))"
                                            aria-label="@($"Remove {t} filter")">&#x2715;</button>
                                </span>
                            }
                            <button class="projects-filter-clear" @onclick="ClearTags">Clear all</button>
                        </div>
                    }

                </div>
            }

            <!-- ── Project grid ── -->
            @if (FilteredProjects.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No projects match that tag.
                </MudAlert>
            }
            else
            {
                <MudGrid Spacing="4">
                    @foreach (var project in FilteredProjects)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <ProjectCard Project="project"
                                         CoverUrl="@ProgrammingService.ResolveCdnUrl(project.Slug, project.Cover)"
                                         OnClick="@(() => Nav.NavigateTo($"/programming/{project.Slug}"))" />
                        </MudItem>
                    }
                </MudGrid>
            }
        }

    </MudContainer>
}
else if (Subpage is not null)
{
    <!-- ═══════════ SUB-PAGE VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo($"/programming/{Slug}"))"
                   Class="mb-6 back-btn">
            @(_currentProject?.Title ?? "Project")
        </MudButton>

        @if (_loadingSubpage)
        {
            <div class="projects-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_subpageError)
        {
            <div class="projects-error">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    Hey, sorry — we couldn't load this page right now. Please try again in a moment.
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="RetrySubPageAsync">
                    Retry
                </MudButton>
            </div>
        }
        else
        {
            <div class="project-detail-header">
                <h1 class="project-detail-title">@(_subpageTitle ?? TitleCaseFromSlug(Subpage))</h1>
                @if (_currentProject is not null)
                {
                    <div class="project-subpage-parent-label">
                        <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                        <span>@_currentProject.Title</span>
                    </div>
                }
            </div>

            @if (_subpageHtml is not null)
            {
                <div class="project-content-scope">
                    <div class="project-content">
                        @((MarkupString)_subpageHtml)
                    </div>
                </div>
            }
        }

    </MudContainer>
}
else
{
    <!-- ═══════════ DETAIL VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/programming"))"
                   Class="mb-6 back-btn">
            All Projects
        </MudButton>

        @if (_loadingProject)
        {
            <div class="projects-loading">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (_projectError)
        {
            <div class="projects-error">
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                    Hey, sorry — we couldn't load this project right now. Please try again in a moment.
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="RetryProjectAsync">
                    Retry
                </MudButton>
            </div>
        }
        else
        {
            @if (_currentProject is not null)
            {
                <div class="project-detail-header">

                    <!-- Cover image -->
                    @if (!string.IsNullOrEmpty(_currentProject.Cover))
                    {
                        <div class="project-detail-cover">
                            <img src="@ProgrammingService.ResolveCdnUrl(_currentProject.Slug, _currentProject.Cover)"
                                 alt="@(!string.IsNullOrEmpty(_currentProject.CoverAlt) ? _currentProject.CoverAlt : _currentProject.Title)"
                                 loading="eager" />
                        </div>
                    }

                    <!-- Title row -->
                    <div class="project-detail-title-row">
                        <h1 class="project-detail-title">@_currentProject.Title</h1>
                        @if (_currentProject.Links is { Count: > 0 })
                        {
                            <div class="project-detail-links">
                                <div class="project-detail-links-row">
                                    @foreach (var link in _currentProject.Links)
                                    {
                                        <a class="project-detail-link-btn"
                                           href="@link.Url"
                                           target="_blank"
                                           rel="noopener noreferrer">
                                            @link.Label
                                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew"
                                                     Size="Size.Small"
                                                     Class="project-detail-link-icon" />
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Meta row: date, license, status -->
                    <div class="project-detail-meta">
                        @if (!string.IsNullOrEmpty(_currentProject.Date))
                        {
                            <span class="project-detail-meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                @FormatDate(_currentProject.Date)
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(_currentProject.License))
                        {
                            <span class="project-detail-meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.Copyright" Size="Size.Small" />
                                @_currentProject.License
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(_currentProject.Status))
                        {
                            <span class="project-detail-status @GetStatusCssClass(_currentProject.Status)">
                                @GetStatusLabel(_currentProject.Status)
                            </span>
                        }
                    </div>

                    <!-- Badges: languages + platform + tags on one row -->
                    @{
                        var hasAnyBadges = _currentProject.Languages.Count > 0
                                        || _currentProject.Platform.Count > 0
                                        || _currentProject.Tags.Count > 0;
                    }
                    @if (hasAnyBadges)
                    {
                        <div class="project-detail-badges">
                            @foreach (var lang in _currentProject.Languages)
                            {
                                <span class="project-detail-lang-badge" style="@GetLanguageStyle(lang)">@lang</span>
                            }
                            @foreach (var plat in _currentProject.Platform)
                            {
                                <span class="project-platform-badge">@plat</span>
                            }
                            @foreach (var tag in _currentProject.Tags)
                            {
                                <span class="project-detail-tag">@tag</span>
                            }
                        </div>
                    }

                </div>

                <!-- ── GitHub repo panel ── -->
                @if (!string.IsNullOrEmpty(_currentProject.Repo))
                {
                    <GitHubRepoPanel RepoUrl="@_currentProject.Repo" />
                }

                <!-- ── Demo link / embed ── -->
                @if (!string.IsNullOrEmpty(_currentProject.DemoUrl))
                {
                    <div class="project-detail-demo">
                        <p class="project-section-label">Demo</p>
                        @if (!string.IsNullOrEmpty(_currentProject.DemoEmbed))
                        {
                            <div class="project-demo-embed-wrap">
                                <iframe src="@_currentProject.DemoEmbed"
                                        class="project-demo-embed"
                                        loading="lazy"
                                        allow="autoplay; fullscreen"
                                        title="@_currentProject.Title demo"
                                        sandbox="allow-scripts allow-same-origin allow-popups">
                                </iframe>
                            </div>
                        }
                        <a class="project-demo-link"
                           href="@_currentProject.DemoUrl"
                           target="_blank"
                           rel="noopener noreferrer">
                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                            Try it live
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew"
                                     Size="Size.Small"
                                     Style="opacity:0.4" />
                        </a>
                    </div>
                }

                <!-- ── Dependencies ── -->
                @if (_currentProject.Dependencies.Count > 0)
                {
                    <div class="project-detail-deps">
                        <p class="project-section-label">Dependencies</p>
                        <div class="project-deps-list">
                            @foreach (var dep in _currentProject.Dependencies)
                            {
                                <span class="project-dep-badge">@dep</span>
                            }
                        </div>
                    </div>
                }

                <!-- ── Sub-page navigation ── -->
                @if (_currentProject.Subpages is { Count: > 0 })
                {
                    <div class="project-subpages-nav">
                        <p class="project-subpages-nav-label">Pages</p>
                        <div class="project-subpages-list">
                            @foreach (var sp in _currentProject.Subpages)
                            {
                                var spSlug = sp;
                                <a class="project-subpage-card"
                                   href="/programming/@_currentProject.Slug/@spSlug">
                                    <MudIcon Icon="@Icons.Material.Filled.Article"
                                             Size="Size.Small"
                                             Class="project-subpage-card-icon" />
                                    <span>@GetSubPageDisplayTitle(spSlug)</span>
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight"
                                             Size="Size.Small"
                                             Class="project-subpage-card-arrow" />
                                </a>
                            }
                        </div>
                    </div>
                }

                <!-- ── Gallery ── -->
                @if (_currentProject.Gallery is { Count: > 0 })
                {
                    <div class="project-detail-gallery">
                        <p class="project-section-label">Gallery</p>
                        <ProjectLightbox Items="@_currentProject.Gallery" Slug="@_currentProject.Slug" />
                    </div>
                }

                <!-- ── Files ── -->
                @if (_currentProject.Files is { Count: > 0 })
                {
                    <div class="project-detail-files">
                        <p class="project-section-label">Files</p>
                        <div class="project-detail-files-row">
                            @foreach (var file in VisibleFiles(_currentProject.Files))
                            {
                                <a class="project-detail-file-btn"
                                   href="@ProgrammingService.ResolveCdnUrl(_currentProject.Slug, file.Src)"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   download>
                                    <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile"
                                             Size="Size.Small"
                                             Class="project-detail-file-icon" />
                                    @file.Label
                                </a>
                            }
                        </div>
                        @if (_currentProject.Files.Count > FilesInitialVisible)
                        {
                            <button class="project-files-toggle"
                                    @onclick="@(() => _filesExpanded = !_filesExpanded)"
                                    aria-expanded="@_filesExpanded.ToString().ToLower()">
                                @if (_filesExpanded)
                                {
                                    <span>Show less</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="18 15 12 9 6 15"/>
                                    </svg>
                                }
                                else
                                {
                                    <span>Show @(_currentProject.Files.Count - FilesInitialVisible) more</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                }
                            </button>
                        }
                    </div>
                }
            }

            <!-- Markdown body -->
            @if (_projectHtml is not null)
            {
                <div class="project-content-scope">
                    <div class="project-content">
                        @((MarkupString)_projectHtml)
                    </div>
                </div>
            }

            <!-- ── Credits ── -->
            @if (_currentProject?.Credits is { Count: > 0 })
            {
                <div class="project-detail-credits">
                    <p class="project-section-label">Credits</p>
                    <ul class="project-credits-list">
                        @foreach (var credit in _currentProject.Credits)
                        {
                            <li class="project-credit-item">
                                <a class="project-credit-link"
                                   href="@credit.Url"
                                   target="_blank"
                                   rel="noopener noreferrer">@credit.Label</a>
                                <span class="project-credit-by">by @credit.Author</span>
                                @if (!string.IsNullOrEmpty(credit.License))
                                {
                                    <span class="project-credit-license">@credit.License</span>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }
        }

    </MudContainer>
}

@code {
    [Parameter] public string? Slug { get; set; }
    [Parameter] public string? Subpage { get; set; }

    private ProjectManifest? _manifest;
    private bool _loadingManifest = true;
    private bool _manifestError   = false;

    private string? _projectHtml;
    private bool _loadingProject = false;
    private bool _projectError   = false;

    private string? _subpageHtml;
    private string? _subpageTitle;
    private bool _loadingSubpage = false;
    private bool _subpageError   = false;

    private string _loadedKey = "##NOT_INITIALIZED##";
    private string CurrentKey => $"{Slug}|{Subpage}";

    private readonly Dictionary<string, string> _subpageTitleCache = new();

    private const int FilesInitialVisible = 3;
    private bool _filesExpanded = false;

    private IEnumerable<FileItem> VisibleFiles(List<FileItem> files) =>
        _filesExpanded ? files : files.Take(FilesInitialVisible);

    // ── Tag filter ────────────────────────────────────────────────────────────

    private readonly HashSet<string> _selectedTags = new(StringComparer.OrdinalIgnoreCase);
    private string _tagQuery             = string.Empty;
    private bool   _showTagSuggestions   = false;
    private bool   _mouseOverSuggestions = false;

    private ProjectEntry? _currentProject =>
        Slug is not null ? _manifest?.Projects.FirstOrDefault(p => p.Slug == Slug) : null;

    private string ComputedPageTitle
    {
        get
        {
            if (Subpage is not null)
            {
                var spTitle   = _subpageTitle ?? TitleCaseFromSlug(Subpage);
                var projTitle = _currentProject?.Title;
                return projTitle is not null
                    ? $"{spTitle} — {projTitle} — Programming — Shaun Broomfield"
                    : $"{spTitle} — Programming — Shaun Broomfield";
            }
            return _currentProject is not null
                ? $"{_currentProject.Title} — Programming — Shaun Broomfield"
                : "Programming — Shaun Broomfield";
        }
    }

    private List<string> AllTags =>
        _manifest?.Projects
            .SelectMany(p => p.Tags)
            .Distinct()
            .OrderBy(t => t)
            .ToList()
        ?? new List<string>();

    private List<string> TagSuggestions =>
        AllTags
            .Where(t => !_selectedTags.Contains(t)
                     && (string.IsNullOrWhiteSpace(_tagQuery)
                         || t.Contains(_tagQuery, StringComparison.OrdinalIgnoreCase)))
            .ToList();

    private List<ProjectEntry> FilteredProjects
    {
        get
        {
            if (_manifest is null) return new List<ProjectEntry>();

            var source = _selectedTags.Count == 0
                ? _manifest.Projects
                : _manifest.Projects.Where(p => _selectedTags.All(t => p.Tags.Contains(t)));

            return source
                .OrderByDescending(p => p.Featured)
                .ToList();
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadManifestAsync();
        _loadedKey = CurrentKey;

        if (Slug is not null)
        {
            if (Subpage is not null)
                await LoadSubPageAsync();
            else
                await LoadProjectAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedKey == "##NOT_INITIALIZED##") return;
        if (CurrentKey == _loadedKey) return;

        _loadedKey = CurrentKey;

        if (Slug is null)
        {
            _projectHtml  = null;
            _projectError = false;
            _subpageHtml  = null;
            _subpageTitle = null;
            _subpageError = false;
        }
        else if (Subpage is not null)
        {
            await LoadSubPageAsync();
        }
        else
        {
            _subpageHtml   = null;
            _subpageTitle  = null;
            _subpageError  = false;
            _filesExpanded = false;
            await LoadProjectAsync();
        }
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadManifestAsync()
    {
        _loadingManifest = true;
        _manifestError   = false;

        var result = await ProgrammingService.FetchManifestAsync();

        _loadingManifest = false;

        if (result is null)
            _manifestError = true;
        else
        {
            _manifest = result;
            _ = WarmSubPageTitlesAsync();
        }
    }

    private async Task WarmSubPageTitlesAsync()
    {
        if (_manifest is null) return;

        var tasks = _manifest.Projects
            .SelectMany(p => (p.Subpages ?? []).Select(sp => WarmSubPageTitleAsync(p.Slug, sp)))
            .ToList();

        await Task.WhenAll(tasks);
    }

    private async Task WarmSubPageTitleAsync(string slug, string subpage)
    {
        var title = await ProgrammingService.FetchSubPageTitleAsync(slug, subpage);
        if (title is not null)
        {
            _subpageTitleCache[subpage] = title;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadProjectAsync()
    {
        _loadingProject = true;
        _projectError   = false;
        _projectHtml    = null;

        var html = await ProgrammingService.FetchProjectHtmlAsync(Slug!);

        _loadingProject = false;

        if (html is null)
            _projectError = true;
        else
            _projectHtml = html;
    }

    private async Task LoadSubPageAsync()
    {
        _loadingSubpage = true;
        _subpageError   = false;
        _subpageHtml    = null;
        _subpageTitle   = null;

        var htmlTask  = ProgrammingService.FetchSubPageHtmlAsync(Slug!, Subpage!);
        var titleTask = ProgrammingService.FetchSubPageTitleAsync(Slug!, Subpage!);

        await Task.WhenAll(htmlTask, titleTask);

        var html  = htmlTask.Result;
        var title = titleTask.Result;

        _loadingSubpage = false;

        if (html is null)
            _subpageError = true;
        else
        {
            _subpageHtml  = html;
            _subpageTitle = title;
        }
    }

    // ── Retry handlers ────────────────────────────────────────────────────────

    private async Task RetryManifestAsync() => await LoadManifestAsync();

    private async Task RetryProjectAsync()
    {
        if (Slug is not null) await LoadProjectAsync();
    }

    private async Task RetrySubPageAsync()
    {
        if (Slug is not null && Subpage is not null) await LoadSubPageAsync();
    }

    // ── Tag filter actions ────────────────────────────────────────────────────

    private void AddTag(string tag)
    {
        _selectedTags.Add(tag);
        _tagQuery             = string.Empty;
        _showTagSuggestions   = false;
        _mouseOverSuggestions = false;
    }

    private void RemoveTag(string tag) => _selectedTags.Remove(tag);

    private void ClearTags()
    {
        _selectedTags.Clear();
        _tagQuery = string.Empty;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string GetSubPageDisplayTitle(string subpage) =>
        _subpageTitleCache.TryGetValue(subpage, out var title)
            ? title
            : TitleCaseFromSlug(subpage);

    private static string TitleCaseFromSlug(string slug) =>
        string.Join(" ", slug.Split('-')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w));

    private static string FormatDate(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
            return dt.ToString("d MMMM yyyy");
        return isoDate;
    }

    private static string GetStatusCssClass(string status) =>
        status.ToLowerInvariant() switch
        {
            "complete"    => "project-detail-status--complete",
            "in-progress" => "project-detail-status--in-progress",
            "wip"         => "project-detail-status--in-progress",
            "abandoned"   => "project-detail-status--abandoned",
            "archived"    => "project-detail-status--abandoned",
            _             => "project-detail-status--default"
        };

    private static string GetStatusLabel(string status) =>
        status.ToLowerInvariant() switch
        {
            "complete"    => "Complete",
            "in-progress" => "In Progress",
            "wip"         => "WIP",
            "abandoned"   => "Abandoned",
            "archived"    => "Archived",
            _             => status
        };

    // Consistent with ProjectCard language colours
    private static string GetLanguageStyle(string language) =>
        language.ToLowerInvariant() switch
        {
            "lua"        => "background:rgba(0,0,178,0.18);color:#5b8ef5;",
            "c#"         => "background:rgba(104,33,122,0.2);color:#c375d9;",
            "python"     => "background:rgba(53,114,165,0.2);color:#69b4f5;",
            "javascript" => "background:rgba(200,170,0,0.15);color:#e0c05a;",
            "typescript" => "background:rgba(49,120,198,0.2);color:#6ba3e0;",
            "rust"       => "background:rgba(200,100,50,0.2);color:#e08a56;",
            "go"         => "background:rgba(0,173,196,0.18);color:#50ccd8;",
            "java"       => "background:rgba(176,114,25,0.2);color:#e0a050;",
            "c++"        => "background:rgba(243,75,125,0.18);color:#e87aab;",
            "c"          => "background:rgba(85,85,85,0.25);color:#aaa;",
