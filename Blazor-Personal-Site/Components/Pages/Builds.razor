@page "/builds"
@page "/builds/{Slug}"
@page "/builds/{Slug}/{Subpage}"

@inject IBuildsService BuildsService
@inject NavigationManager Nav

<PageTitle>@ComputedPageTitle</PageTitle>

@if (Slug is null)
{
    <!-- ═══════════ LIST VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">

        <MudText Typo="Typo.h3" Class="mb-2">Builds</MudText>
        <MudText Typo="Typo.body1" Style="opacity: 0.75;" Class="mb-8">
            3D-printed projects from practical desk organisers to structural engineering parts.
        </MudText>

        <BuildsListView IsLoading="_isLoadingManifest"
                        HasError="_hasManifestError"
                        Manifest="_manifest"
                        OnRetry="RetryManifestAsync"
                        OnBuildSelected="@(slug => Nav.NavigateTo($"/builds/{slug}"))" />

    </MudContainer>
}
else if (Subpage is not null)
{
    <!-- ═══════════ SUB-PAGE VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo($"/builds/{Slug}"))"
                   Class="mb-6 back-btn">
            @(_currentBuild?.Title ?? "Build")
        </MudButton>

        <BuildSubPageView IsLoading="_isLoadingSubpage"
                          HasError="_hasSubpageError"
                          SubpageSlug="@Subpage"
                          Title="@_subpageTitle"
                          Html="@_subpageHtml"
                          ParentBuild="_currentBuild"
                          OnRetry="RetrySubPageAsync" />

    </MudContainer>
}
else
{
    <!-- ═══════════ DETAIL VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/builds"))"
                   Class="mb-6 back-btn">
            All Builds
        </MudButton>

        <BuildDetailView IsLoading="_isLoadingBuild"
                         HasError="_hasBuildError"
                         Build="_currentBuild"
                         BuildHtml="@_buildHtml"
                         SubpageTitleCache="_subpageTitleCache"
                         OnRetry="RetryBuildAsync" />

    </MudContainer>
}

@code {
    [Parameter] public string? Slug { get; set; }
    [Parameter] public string? Subpage { get; set; }

    private BuildManifest? _manifest;
    private bool _isLoadingManifest = true;
    private bool _hasManifestError   = false;

    private string? _buildHtml;
    private bool _isLoadingBuild = false;
    private bool _hasBuildError   = false;

    private string? _subpageHtml;
    private string? _subpageTitle;
    private bool _isLoadingSubpage = false;
    private bool _hasSubpageError   = false;

    // Tracks the combined (Slug, Subpage) key we've already loaded to avoid
    // redundant fetches on parameter-change cycles.
    private string _loadedKey = "##NOT_INITIALIZED##";
    private string CurrentKey => $"{Slug}|{Subpage}";

    // Cached sub-page display titles (stem → title) so the nav cards
    // can show proper names once the titles are fetched in the background.
    private readonly Dictionary<string, string> _subpageTitleCache = new();

    private BuildEntry? _currentBuild =>
        Slug is not null ? _manifest?.Builds.FirstOrDefault(b => b.Slug == Slug) : null;

    private string ComputedPageTitle
    {
        get
        {
            if (Subpage is not null)
            {
                var spTitle    = _subpageTitle ?? MarkdownProcessor.TitleCaseFromSlug(Subpage);
                var buildTitle = _currentBuild?.Title;
                return buildTitle is not null
                    ? $"{spTitle} — {buildTitle} — Builds — Shaun Broomfield"
                    : $"{spTitle} — Builds — Shaun Broomfield";
            }
            return _currentBuild is not null
                ? $"{_currentBuild.Title} — Builds — Shaun Broomfield"
                : "Builds — Shaun Broomfield";
        }
    }

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadManifestAsync();
        _loadedKey = CurrentKey;

        if (Slug is not null)
        {
            if (Subpage is not null)
                await LoadSubPageAsync();
            else
                await LoadBuildAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Skip on the very first render — handled by OnInitializedAsync above.
        if (_loadedKey == "##NOT_INITIALIZED##") return;

        if (CurrentKey == _loadedKey) return;

        _loadedKey = CurrentKey;

        if (Slug is null)
        {
            // Navigated back to the list — clear build/subpage state
            _buildHtml       = null;
            _hasBuildError   = false;
            _subpageHtml     = null;
            _subpageTitle    = null;
            _hasSubpageError = false;
        }
        else if (Subpage is not null)
        {
            await LoadSubPageAsync();
        }
        else
        {
            // Navigated to a build detail — clear any lingering sub-page state
            _subpageHtml     = null;
            _subpageTitle    = null;
            _hasSubpageError = false;
            await LoadBuildAsync();
        }
    }

    // ── Data loading ─────────────────────────────────────────────────────────

    private async Task LoadManifestAsync()
    {
        _isLoadingManifest = true;
        _hasManifestError   = false;

        var manifest = await BuildsService.FetchManifestAsync();

        _isLoadingManifest = false;

        if (manifest is null)
            _hasManifestError = true;
        else
        {
            _manifest = manifest;
            // Eagerly warm sub-page titles in the background so nav cards
            // can show proper names without a visible delay.
            _ = WarmSubPageTitlesAsync();
        }
    }

    private async Task WarmSubPageTitlesAsync()
    {
        if (_manifest is null) return;

        var tasks = _manifest.Builds
            .SelectMany(b => (b.Subpages ?? []).Select(sp => WarmSubPageTitleAsync(b.Slug, sp)))
            .ToList();

        await Task.WhenAll(tasks);
    }

    private async Task WarmSubPageTitleAsync(string slug, string subpage)
    {
        var title = await BuildsService.FetchSubPageTitleAsync(slug, subpage);
        if (title is not null)
        {
            _subpageTitleCache[subpage] = title;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadBuildAsync()
    {
        _isLoadingBuild = true;
        _hasBuildError   = false;
        _buildHtml       = null;

        var html = await BuildsService.FetchBuildHtmlAsync(Slug!);

        _isLoadingBuild = false;

        if (html is null)
            _hasBuildError = true;
        else
            _buildHtml = html;
    }

    private async Task LoadSubPageAsync()
    {
        _isLoadingSubpage = true;
        _hasSubpageError   = false;
        _subpageHtml       = null;
        _subpageTitle      = null;

        var htmlTask  = BuildsService.FetchSubPageHtmlAsync(Slug!, Subpage!);
        var titleTask = BuildsService.FetchSubPageTitleAsync(Slug!, Subpage!);

        await Task.WhenAll(htmlTask, titleTask);

        var html  = htmlTask.Result;
        var title = titleTask.Result;

        _isLoadingSubpage = false;

        if (html is null)
            _hasSubpageError = true;
        else
        {
            _subpageHtml  = html;
            _subpageTitle = title;
        }
    }

    // ── Retry handlers ───────────────────────────────────────────────────────

    private async Task RetryManifestAsync() => await LoadManifestAsync();

    private async Task RetryBuildAsync()
    {
        if (Slug is not null) await LoadBuildAsync();
    }

    private async Task RetrySubPageAsync()
    {
        if (Slug is not null && Subpage is not null) await LoadSubPageAsync();
    }
}
