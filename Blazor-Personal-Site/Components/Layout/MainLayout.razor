@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">Shaun Broomfield</MudText>
        <MudSpacer />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="mt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _drawerOpen = false;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };
    }


    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    // _lightPalette is intentionally kept — reserved for future components that
    // benefit from a light surface (e.g. an inline markdown document viewer).
    private readonly PaletteLight _lightPalette = new()
    {
        // Icelandic Volcanic Terrain palette — light mode
        Primary = "#5E7A2A",                          // Crater Moss — deep rich green for light bg
        Black = "#2A2723",                            // Ash Plain instead of pure black
        AppbarText = "#2A2723",                       // Ash Plain — dark text on light bar
        AppbarBackground = "rgba(245,242,236,0.9)",   // Warm off-white with transparency
        DrawerBackground = "#F5F2EC",                 // Warm white
        GrayLight = "#D4D0C8",                        // Warm light grey
        GrayLighter = "#F0EDE6",                      // Very light warm grey
    };

    private readonly PaletteDark _darkPalette = new()
    {
        // Icelandic Volcanic Terrain palette — dark mode
        Primary = "#7A9E35",                          // Highland Green — interactive elements
        Surface = "#3D3A35",                          // Tephra — card / panel backgrounds
        Background = "#2A2723",                       // Ash Plain — page background
        BackgroundGray = "#1F1D1A",                   // Below-ash-plain depth layer
        AppbarText = "#E8E4DC",                       // Primary Text
        AppbarBackground = "rgba(42,39,35,0.85)",     // Ash Plain with transparency
        DrawerBackground = "#1A1815",                 // Deep Volcanic — darker, warmer than Ash Plain
        ActionDefault = "#A09890",                    // Muted Text
        ActionDisabled = "#A098904D",                 // Muted Text — transparent
        ActionDisabledBackground = "#504C454D",       // Cinder — transparent
        TextPrimary = "#E8E4DC",                      // Warm off-white body copy
        TextSecondary = "#A09890",                    // Muted Text — captions / labels
        TextDisabled = "#E8E4DC33",                   // Primary Text — transparent
        DrawerIcon = "#A09890",                       // Muted Text
        DrawerText = "#A09890",                       // Muted Text
        GrayLight = "#504C45",                        // Cinder — elevated surfaces
        GrayLighter = "#3D3A35",                      // Tephra
        Info = "#8A9BA8",                             // Meltwater — cool secondary accent
        Success = "#9CC240",                          // Lichen Flash — vivid green
        Warning = "#ffb545",
        Error = "#ff3f5f",
        LinesDefault = "#504C45",                     // Cinder
        TableLines = "#504C45",                       // Cinder
        Divider = "#3D3A35",                          // Tephra
        OverlayLight = "#2A272380",                   // Ash Plain — semi-transparent
    };

}


