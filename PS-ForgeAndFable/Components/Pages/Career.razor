@page "/career"

<PageTitle>Career — Shaun Broomfield</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="career-page">

    <div class="career-header mb-10">
        <MudText Typo="Typo.h3" Class="career-title mb-2">Career</MudText>
        <MudText Typo="Typo.body1" Class="career-subtitle">
            The professional side of things. Where I've worked and what I've done.
        </MudText>
    </div>

    <CareerTimeline>

        <CareerTimelineEntry
            Company="Labman Automation"
            DateRange="2018 — 2019"
            Role="Apprentice Software Engineer"
            LogoSrc="images/logos/labman.svg"
            Url="https://www.labmanautomation.com/"
            Side="left" />

        <CareerTimelineEntry
            Company="Tascomp Limited"
            DateRange="2019 — 2024"
            PreviousRole="Apprentice Software Engineer"
            Role="Software Engineer"
            LogoSrc="images/logos/tascomp.png"
            Url="https://www.tascomp.com"
            Side="right" />

        <CareerTimelineEntry
            Company="DEF Software"
            DateRange="2024 — Present"
            Role="Business Logic Developer"
            LogoSrc="images/logos/def.webp"
            Url="https://www.def.co.uk/"
            Side="left" />

    </CareerTimeline>
    <div class="py-6"></div>
    <div class="career-resume-section">
        <MudText Typo="Typo.body1" Class="career-resume-intro">
            Want the full picture? The résumé has the details.
        </MudText>
        <div class="py-2"></div>
        <div class="career-resume-track">
            <a class="career-resume-pill"
               href="https://github.com/Broomfields/Resume/raw/main/LaTeX/Resume/Resume%20-%20Shaun%20Broomfield.pdf"
               target="_blank"
               rel="noopener noreferrer">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                <span class="career-resume-pill-label">Résumé</span>
            </a>
        </div>
    </div>

</MudContainer>
