@page "/programming"
@page "/programming/{Slug}"
@page "/programming/{Slug}/{Subpage}"

@inject IProgrammingService ProgrammingService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@ComputedPageTitle</PageTitle>

@if (Slug is null)
{
    <!-- ═══════════ LIST VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">

        <MudText Typo="Typo.h3" Class="mb-2">Programming Projects</MudText>
        <MudText Typo="Typo.body1" Style="opacity: 0.75;" Class="mb-8">
            Software I've built out of curiosity or necessity. Usually both, honestly.
        </MudText>

        <ProgrammingListView IsLoading="_isLoadingManifest"
                             HasError="_hasManifestError"
                             Manifest="_manifest"
                             OnRetry="RetryManifestAsync"
                             OnProjectSelected="@(slug => Nav.NavigateTo($"/programming/{slug}"))" />

    </MudContainer>
}
else if (Subpage is not null)
{
    <!-- ═══════════ SUB-PAGE VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo($"/programming/{Slug}"))"
                   Class="mb-6 back-btn">
            @(_currentProject?.Title ?? "Project")
        </MudButton>

        <ProgrammingSubPageView IsLoading="_isLoadingSubpage"
                                HasError="_hasSubpageError"
                                SubpageSlug="@Subpage"
                                Title="@_subpageTitle"
                                Html="@_subpageHtml"
                                ParentProject="_currentProject"
                                OnRetry="RetrySubPageAsync" />

    </MudContainer>
}
else
{
    <!-- ═══════════ DETAIL VIEW ═══════════ -->
    <MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/programming"))"
                   Class="mb-6 back-btn">
            All Projects
        </MudButton>

        <ProgrammingDetailView IsLoading="_isLoadingProject"
                               HasError="_hasProjectError"
                               Project="_currentProject"
                               ProjectHtml="@_projectHtml"
                               SubpageTitleCache="_subpageTitleCache"
                               OnRetry="RetryProjectAsync" />

    </MudContainer>
}

@code {
    [Parameter] public string? Slug { get; set; }
    [Parameter] public string? Subpage { get; set; }

    private ProjectManifest? _manifest;
    private bool _isLoadingManifest = true;
    private bool _hasManifestError   = false;

    private string? _projectHtml;
    private bool _isLoadingProject = false;
    private bool _hasProjectError   = false;

    private string? _subpageHtml;
    private string? _subpageTitle;
    private bool _isLoadingSubpage = false;
    private bool _hasSubpageError   = false;

    private string _loadedKey = "##NOT_INITIALIZED##";
    private string CurrentKey => $"{Slug}|{Subpage}";

    private readonly Dictionary<string, string> _subpageTitleCache = new();

    private ProjectEntry? _currentProject =>
        Slug is not null ? _manifest?.Projects.FirstOrDefault(p => p.Slug == Slug) : null;

    private string ComputedPageTitle
    {
        get
        {
            if (Subpage is not null)
            {
                var spTitle   = _subpageTitle ?? MarkdownProcessor.TitleCaseFromSlug(Subpage);
                var projTitle = _currentProject?.Title;
                return projTitle is not null
                    ? $"{spTitle} — {projTitle} — Programming — Shaun Broomfield"
                    : $"{spTitle} — Programming — Shaun Broomfield";
            }
            return _currentProject is not null
                ? $"{_currentProject.Title} — Programming — Shaun Broomfield"
                : "Programming — Shaun Broomfield";
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("renderMermaid");
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadManifestAsync();
        _loadedKey = CurrentKey;

        if (Slug is not null)
        {
            if (Subpage is not null)
                await LoadSubPageAsync();
            else
                await LoadProjectAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedKey == "##NOT_INITIALIZED##") return;
        if (CurrentKey == _loadedKey) return;

        _loadedKey = CurrentKey;

        if (Slug is null)
        {
            _projectHtml     = null;
            _hasProjectError = false;
            _subpageHtml     = null;
            _subpageTitle    = null;
            _hasSubpageError = false;
        }
        else if (Subpage is not null)
        {
            await LoadSubPageAsync();
        }
        else
        {
            _subpageHtml     = null;
            _subpageTitle    = null;
            _hasSubpageError = false;
            await LoadProjectAsync();
        }
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadManifestAsync()
    {
        _isLoadingManifest = true;
        _hasManifestError   = false;

        var manifest = await ProgrammingService.FetchManifestAsync();

        _isLoadingManifest = false;

        if (manifest is null)
            _hasManifestError = true;
        else
        {
            _manifest = manifest;
            _ = WarmSubPageTitlesAsync();
        }
    }

    private async Task WarmSubPageTitlesAsync()
    {
        if (_manifest is null) return;

        var tasks = _manifest.Projects
            .SelectMany(p => (p.Subpages ?? []).Select(sp => WarmSubPageTitleAsync(p.Slug, sp)))
            .ToList();

        await Task.WhenAll(tasks);
    }

    private async Task WarmSubPageTitleAsync(string slug, string subpage)
    {
        var title = await ProgrammingService.FetchSubPageTitleAsync(slug, subpage);
        if (title is not null)
        {
            _subpageTitleCache[subpage] = title;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadProjectAsync()
    {
        _isLoadingProject = true;
        _hasProjectError   = false;
        _projectHtml       = null;

        var html = await ProgrammingService.FetchProjectHtmlAsync(Slug!);

        _isLoadingProject = false;

        if (html is null)
            _hasProjectError = true;
        else
            _projectHtml = html;
    }

    private async Task LoadSubPageAsync()
    {
        _isLoadingSubpage = true;
        _hasSubpageError   = false;
        _subpageHtml       = null;
        _subpageTitle      = null;

        var htmlTask  = ProgrammingService.FetchSubPageHtmlAsync(Slug!, Subpage!);
        var titleTask = ProgrammingService.FetchSubPageTitleAsync(Slug!, Subpage!);

        await Task.WhenAll(htmlTask, titleTask);

        var html  = htmlTask.Result;
        var title = titleTask.Result;

        _isLoadingSubpage = false;

        if (html is null)
            _hasSubpageError = true;
        else
        {
            _subpageHtml  = html;
            _subpageTitle = title;
        }
    }

    // ── Retry handlers ────────────────────────────────────────────────────────

    private async Task RetryManifestAsync() => await LoadManifestAsync();

    private async Task RetryProjectAsync()
    {
        if (Slug is not null) await LoadProjectAsync();
    }

    private async Task RetrySubPageAsync()
    {
        if (Slug is not null && Subpage is not null) await LoadSubPageAsync();
    }
}
