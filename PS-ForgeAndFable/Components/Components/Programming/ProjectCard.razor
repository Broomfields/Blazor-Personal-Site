@using ForgeAndFable.Models

<div class="project-card @(Project.IsFeatured ? "project-card--featured" : "")"
     @onclick="OnClick" role="button" tabindex="0"
     @onkeydown="HandleKeyDown"
     aria-label="@($"View project: {Project.Title}")">

    <div class="project-card-cover @(string.IsNullOrEmpty(CoverUrl) ? "project-card-cover--placeholder" : "")">
        @if (!string.IsNullOrEmpty(CoverUrl))
        {
            <img src="@CoverUrl"
                 alt="@(!string.IsNullOrEmpty(Project.CoverAlt) ? Project.CoverAlt : Project.Title)"
                 loading="lazy"
                 onerror="this.closest('.project-card-cover').classList.add('project-card-cover--placeholder'); this.remove();" />
        }
        <MudIcon Icon="@Icons.Material.Filled.DeveloperBoard" Size="Size.Large" Class="project-card-placeholder-icon" />
    </div>

    <div class="project-card-body">

        <div class="project-card-meta">
            @{
                var (statusClass, statusLabel) = GetStatusBadge(Project.Status);
            }
            @if (!string.IsNullOrEmpty(statusLabel))
            {
                <span class="project-card-badge @statusClass">@statusLabel</span>
            }
            @if (Project.IsFeatured)
            {
                <span class="project-card-featured-star" title="Featured project" aria-label="Featured project">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                </span>
            }
        </div>

        <h3 class="project-card-title">@Project.Title</h3>
        <p class="project-card-desc">@Project.Description</p>

        @if (Project.Languages.Count > 0)
        {
            <div class="project-card-languages">
                @foreach (var lang in Project.Languages.Take(4))
                {
                    <span class="project-lang-badge" style="@LanguageStyles.GetBadgeStyle(lang)">@lang</span>
                }
            </div>
        }

        @if (Project.Tags.Count > 0)
        {
            <div class="project-card-tags">
                @foreach (var tag in Project.Tags)
                {
                    <span class="project-card-tag">@tag</span>
                }
            </div>
        }

        <div class="project-card-footer">
            <span class="project-card-date">@FormatDate(Project.Date)</span>
            @if (!string.IsNullOrEmpty(Project.Repo))
            {
                <span class="project-card-repo-hint" aria-label="Has GitHub repository">
                    <svg height="14" viewBox="0 0 16 16" width="14" fill="currentColor" aria-hidden="true">
                        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                    </svg>
                </span>
            }
        </div>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProjectEntry Project { get; set; } = default!;
    [Parameter] public string CoverUrl { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await OnClick.InvokeAsync();
    }

    private static string FormatDate(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
            return dt.ToString("d MMMM yyyy");
        return isoDate;
    }

    private static (string CssClass, string Label) GetStatusBadge(string status) =>
        status.ToLowerInvariant() switch
        {
            "complete"    => ("project-card-badge--complete",    "Complete"),
            "in-progress" => ("project-card-badge--in-progress", "In Progress"),
            "wip"         => ("project-card-badge--in-progress", "WIP"),
            "abandoned"   => ("project-card-badge--abandoned",   "Abandoned"),
            "archived"    => ("project-card-badge--abandoned",   "Archived"),
            _             => ("project-card-badge--status",      status)
        };

}
