@using ForgeAndFable.Models

<div class="build-card @(Build.IsFeatured ? "build-card--featured" : "")"
     @onclick="OnClick" role="button" tabindex="0"
     @onkeydown="HandleKeyDown"
     aria-label="@($"View build: {Build.Title}")">

    <div class="build-card-cover @(string.IsNullOrEmpty(CoverUrl) ? "build-card-cover--placeholder" : "")">
        @if (!string.IsNullOrEmpty(CoverUrl))
        {
            <img src="@CoverUrl"
                 alt="@(!string.IsNullOrEmpty(Build.CoverAlt) ? Build.CoverAlt : Build.Title)"
                 loading="lazy"
                 onerror="this.closest('.build-card-cover').classList.add('build-card-cover--placeholder'); this.remove();" />
        }
        <MudIcon Icon="@Icons.Material.Filled.Construction" Size="Size.Large" Class="build-card-placeholder-icon" />
    </div>

    <div class="build-card-body">

        <div class="build-card-meta">
            @if (!string.IsNullOrEmpty(Build.CadTool))
            {
                <span class="build-card-badge build-card-badge--tool">@Build.CadTool</span>
            }
            @{
                var (statusClass, statusLabel) = GetStatusBadge(Build.Status);
            }
            @if (!string.IsNullOrEmpty(statusLabel))
            {
                <span class="build-card-badge @statusClass">@statusLabel</span>
            }
            @if (Build.IsFeatured)
            {
                <span class="build-card-featured-star" title="Featured build" aria-label="Featured build">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                </span>
            }
        </div>

        <h3 class="build-card-title">@Build.Title</h3>
        <p class="build-card-desc">@Build.Description</p>

        @if (Build.Tags.Count > 0)
        {
            <div class="build-card-tags">
                @foreach (var tag in Build.Tags)
                {
                    <span class="build-card-tag">@tag</span>
                }
            </div>
        }

        <span class="build-card-date">@FormatDate(Build.Date)</span>

    </div>
</div>

@code {
    [Parameter, EditorRequired] public BuildEntry Build { get; set; } = default!;
    [Parameter] public string CoverUrl { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await OnClick.InvokeAsync();
    }

    private static string FormatDate(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
            return dt.ToString("d MMMM yyyy");
        return isoDate;
    }

    private static (string CssClass, string Label) GetStatusBadge(string status) =>
        status.ToLowerInvariant() switch
        {
            "complete"    => ("build-card-badge--complete",    "Complete"),
            "in-progress" => ("build-card-badge--in-progress", "In Progress"),
            "wip"         => ("build-card-badge--in-progress", "WIP"),
            "abandoned"   => ("build-card-badge--abandoned",   "Abandoned"),
            _             => ("build-card-badge--status",      status)
        };
}
